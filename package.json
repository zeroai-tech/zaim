{
  "name": "zaim",
  "version": "0.1.0",
  "private": true,
  "description": "Zaim — a secure, stylish mail client with an agent API. Human webapp + CLI + AI-agent control (Claude Code, Gemini, Codex). By ZeroAI.",
  "type": "module",
  "bin": {
    "zaim": "./bin/zaim.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cli": "node ./bin/zaim.mjs",
    "desktop:dev": "next build && electron .",
    "desktop:dist": "next build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "imapflow": "^1.0.171",
    "mailparser": "^3.7.2",
    "next": "^15.1.0",
    "nodemailer": "^6.9.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "tech.zeroai.zaim",
    "productName": "Zaim",
    "files": [
      "electron/**",
      ".next/standalone/**",
      ".next/static/**",
      "public/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "icon": "public/icon.png",
      "target": "zip"
    },
    "win": {
      "icon": "public/icon.png",
      "target": "zip"
    },
    "linux": {
      "icon": "public/icon.png",
      "target": "AppImage"
    }
  }
}
