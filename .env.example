# ── ZAIM server config (never commit real values) ──────────────────────────────
# Agent + webapp API key (generate: openssl rand -hex 32)
ZAIM_API_KEY=

# Optional: AES key to store IMAP/SMTP passwords encrypted at rest.
# When set, use `zaim encrypt "<password>"` and paste the enc:... value below.
ZAIM_ENC_KEY=

# IMAP (inbound)
ZAIM_IMAP_HOST=
ZAIM_IMAP_PORT=993
ZAIM_IMAP_SECURE=true
ZAIM_IMAP_USER=
ZAIM_IMAP_PASS=

# SMTP (outbound) — falls back to IMAP user/pass if omitted
ZAIM_SMTP_HOST=
ZAIM_SMTP_PORT=465
ZAIM_SMTP_SECURE=true
ZAIM_SMTP_USER=
ZAIM_SMTP_PASS=

# Sender identity
ZAIM_FROM_NAME=
ZAIM_FROM_EMAIL=
ZAIM_REPLY_TO=
